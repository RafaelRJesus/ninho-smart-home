PORT=3001
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=
# Brasil normalmente usa o data center Western America (us).
# Valores aceitos: us, eu, cn, in
TUYA_REGION=us
TUYA_POLL_INTERVAL_MS=15000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
DATA_FILE=./data/state.json
DATABASE_URL=
DATABASE_SSL=true
DATABASE_POOL_SIZE=5

# Gere com: openssl rand -hex 32
AUTH_SECRET=
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY=false
REQUIRE_HTTPS=true
# Opcional: SHA-256 de um PIN exigido para executar cenas/automações críticas.
CRITICAL_ACTION_PIN_SHA256=
# Em produção, proteja /api/metrics com este token.
METRICS_TOKEN=
# 32 bytes em base64 ou 64 caracteres hexadecimais. Nunca salve no banco.
INTEGRATION_MASTER_KEY=
INTEGRATION_KEY_VERSION=v1

# Cloudflare Turnstile. Ative apenas depois de cadastrar o hostname do app.
TURNSTILE_REQUIRED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_HOSTNAME=

# Home Assistant opcional. Crie um Long-Lived Access Token no perfil do HA.
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=
